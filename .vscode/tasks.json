{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Package ModelExtras",
            "type": "shell",
            "command": "bash",
            "args": [
                "./archive.sh"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "bash",
            "args": [
                "./debug.sh"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "bash",
            "args": [
                "./release.sh"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Start Wine GDB Server",
            "type": "shell",
            "group": "build",
            "command": "bash",
            "args": [
                "-c",
                "winedbg --gdb --port 12345 '/mnt/p2/Games/GTA San Andreas/gta_sa.exe'"
            ],
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*winedbg.*",
                    "endsPattern": "^.*(gdbserver|listening|ready).*"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Run GTA SA",
            "type": "shell",
            "command": "bash",
            "args": [
                "./run.sh"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Debug GTA SA",
            "type": "shell",
            "command": "bash",
            "args": [
                "./debug_run.sh"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Debug & Run",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "./debug.sh && ./run.sh"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Release & Run",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "./release.sh && ./run.sh"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "group": "build",
            "problemMatcher": []
        }
    ]
}