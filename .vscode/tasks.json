{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Package ModelExtras",
            "type": "shell",
            "command": "./archive.sh",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "./debug.sh",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "./release.sh",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Start Wine GDB Server",
            "type": "shell",
            "group": "build",
            "command": "env",
            "args": [
                "-u",
                "VIRTUAL_ENV",
                "winedbg",
                "--gdb",
                "--port",
                "12345",
                "/mnt/p2/Games/GTA San Andreas/gta_sa.exe"
            ],
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*winedbg.*",
                    "endsPattern": "^.*(gdbserver|listening|ready).*"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Run GTA SA",
            "type": "shell",
            "command": "./run.sh",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Debug & Run",
            "type": "shell",
            "command": "./debug.sh && ./run.sh",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Release & Run",
            "type": "shell",
            "command": "./release.sh && ./run.sh",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "group": "build",
            "problemMatcher": []
        }
    ]
}